# Database (Neon Postgres - free tier at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Basic Auth for AEP endpoint
BASIC_AUTH_USERNAME=aep_test_user
BASIC_AUTH_PASSWORD=your_secure_password_here

# LaunchDarkly (optional - set ENABLED=true to activate forwarding)
LAUNCHDARKLY_ENABLED=false
LAUNCHDARKLY_API_KEY=api-key-here
LAUNCHDARKLY_PROJECT_KEY=default
LAUNCHDARKLY_ENVIRONMENT_KEY=production

# Cleanup - raw events older than this many days are auto-purged
EVENT_RETENTION_DAYS=7
